{
  "projects": {
    "your-project": {
      "path": "/path/to/your-project",
      "branch": "master",
      "steps": [
        "git pull origin master",
        "npm install",
        "npm run build",
        "pm2 restart your-project"
      ]
    },
    "generic-web-app": {
      "path": "/srv/your-app-path",
      "branch": "master",
      "steps": [
        "git pull origin master",
        "cd frontend && npm install && npm run build",
        "systemctl --user restart your-app-service"
      ]
    }
  }
}
